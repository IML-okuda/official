        position: relative;
        padding-left: 0.75rem;
        line-height: 1.4;
    }

    .title::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0.2em;
        width: 4px;
        height: 2.4rem;
        background: #7c3aed;
        border-radius: 2px;
    }

    .sub-title {
        margin: 1rem 0 0.5rem;
        padding-bottom: 0.25rem;
        border-bottom: 1px solid rgba(0,0,0,.12);
    }

    .research-body {
        font-size: clamp(16px, 1.6vw, 18px);
        color: #222;
        line-height: 1.8;
        max-width: 38em;
        margin-inline: auto;
        margin-block: 0.9em 1.2em;
        overflow-wrap: anywhere;
        text-wrap: pretty;
    }

    .research-body p {
        text-indent: 1em;
    }

    .research-body ul {
        padding-left: 1.2rem;
        padding-right: 1.25rem;
        list-style-type: disc;
        margin-block: 0.5rem 1.2rem;
    }

    .research-body li {
        margin-bottom: 0.5rem;
        line-height: 1.6;
    }

    strong {
        font-weight: 600;
    }

    a {
        color: #000000;
        text-decoration: underline;
        text-decoration-thickness: 0.08em;
        text-underline-offset: 0.18em;
    }

    a:hover {
        color: #1d4ed8;
        text-decoration-thickness: 0.12em;
    }

    a:visited {
        color: #6d1d95;
    }

    .img-card {
        display: block;
        background-color: #ffffff;
        padding: 10px;
        width: 300px;
        height: auto;
        margin: 0 auto;
        border-radius: 10px;
        line-height: 0;
        border: 1px solid rgba(0, 0, 0, 0.12);
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
    }

    .img-card img {
        display: block;
        max-width: 100%;
        height: auto;
        border-radius: 6px;
    }

    .img-cap {
        margin-top: 8px;
        font-size: 0.875rem;
        font-weight: bold;
        color: var(--cap-color);
        text-align: center;
        line-height: 1.6;
    }
</style>
